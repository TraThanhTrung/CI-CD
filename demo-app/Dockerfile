FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY app.py .

EXPOSE 5000

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s CMD python -c "import urllib.request; import sys; resp = urllib.request.urlopen('http://127.0.0.1:5000/health'); sys.exit(0 if resp.status == 200 else 1)"

CMD ["python", "app.py"]
